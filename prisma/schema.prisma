// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Faculty {
  id           String               @id @default(uuid())
  name         String               @unique
  buildingName String?
  description  String?
  currentScore Float                @default(0.0)
  inspections  OfficialInspection[]
  responses    UserResponse[]
}

model AssessmentPeriod {
  id          String               @id @default(uuid())
  month       Int
  year        Int
  isActive    Boolean              @default(true)
  inspections OfficialInspection[]
  responses   UserResponse[]

  @@unique([month, year])
}

model OfficialInspection {
  id             String           @id @default(uuid())
  facultyId      String
  periodId       String
  criteriaScores Json             // JSON storing exact points out of max values (e.g. {"cleanliness": 15, "wasteManagement": 18})
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  faculty        Faculty          @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  period         AssessmentPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([facultyId, periodId])
}

enum UserRole {
  STAFF
  STUDENT
}

model UserResponse {
  id        String           @id @default(uuid())
  facultyId String
  periodId  String
  role      UserRole
  responses Json             // JSON storing 1-5 scale ratings mapped to criteria (e.g. {"hygiene": 4, "odor": 5})
  createdAt DateTime         @default(now())
  faculty   Faculty          @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  period    AssessmentPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
}
