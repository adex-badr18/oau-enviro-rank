// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Faculty {
  id            String                @id @default(uuid())
  name          String                @unique
  buildingName  String?
  description   String?
  currentScore  Float                 @default(0.0)
  inspections   OfficialInspection[]
  responses     UserResponse[]
  monthlyScores MonthlyFacultyScore[]
}

model AssessmentPeriod {
  id            String                @id @default(uuid())
  month         Int
  year          Int
  isActive      Boolean               @default(true)
  inspections   OfficialInspection[]
  responses     UserResponse[]
  monthlyScores MonthlyFacultyScore[]

  @@unique([month, year])
}

model OfficialInspection {
  id             String           @id @default(uuid())
  facultyId      String
  periodId       String
  criteriaScores Json             // JSON storing exact points out of max values (e.g. {"cleanliness": 15, "wasteManagement": 18})
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  faculty        Faculty          @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  period         AssessmentPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([facultyId, periodId])
}

enum UserRole {
  STAFF
  STUDENT
}

model UserResponse {
  id           String           @id @default(uuid())
  facultyId    String
  periodId     String
  role         UserRole
  responses    Json             // JSON storing 1-5 scale ratings mapped to criteria (e.g. {"hygiene": 4, "odor": 5})
  respondentId String?          @map("respondent_id")
  createdAt    DateTime         @default(now())
  faculty      Faculty          @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  period       AssessmentPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)
}

enum UserRoleEnum {
  superadmin
  admin
}

model Profile {
  id           String       @id @default(uuid()) @db.Uuid
  email        String       @unique
  passwordHash String       @map("password_hash")
  role         UserRoleEnum @default(admin)
  isActive     Boolean      @default(true) @map("is_active")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  @@map("profiles")
}


model MonthlyFacultyScore {
  id             String           @id @default(uuid())
  facultyId      String           @map("faculty_id")
  periodId       String           @map("period_id")
  finalScore     Float            @map("final_score")
  scoreBreakdown Json             @map("score_breakdown")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  faculty        Faculty          @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  period         AssessmentPeriod @relation(fields: [periodId], references: [id], onDelete: Cascade)

  @@unique([facultyId, periodId])
  @@map("monthly_faculty_scores")
}
